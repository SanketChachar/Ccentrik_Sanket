<mvc:View
    controllerName="zmm_sbc_2903.controller.Update"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:form="sap.ui.layout.form"
  displayBlock="true">

  <Page title="Update Material" showNavButton="true" navButtonPress="onBack">

    <content>
      <VBox class="sapUiMediumMargin">
        <Label text="Material Number"/>
        <HBox>
          <Input id="upd_searchMatnr" placeholder="Enter Material Number to update"/>
          <Button text="Load" press="onLoad" type="Emphasized"
                  icon="sap-icon://download" class="sapUiSmallMarginBegin"/>
        </HBox>
      </VBox>

      <form:SimpleForm
        id="upd_updateForm"
        editable="true"
        layout="ResponsiveGridLayout"
        title="Edit Material Data"
        visible="false"
        class="sapUiMediumMargin">

        <form:content>
          <Label text="Material Type"/>
          <Input id="upd_mtart" value="{updateModel>/MTART}"/>

          <Label text="Industry Sector"/>
          <Input id="upd_mbrsh" value="{updateModel>/MBRSH}"/>

          <Label text="Material Group"/>
          <Input id="upd_matkl" value="{updateModel>/MATKL}"/>

          <Label text="Status"/>
          <Input id="upd_pstat" value="{updateModel>/PSTAT}"/>
        </form:content>

      </form:SimpleForm>
    </content>

    <footer>
      <OverflowToolbar>
        <ToolbarSpacer/>
        <Button text="Update" type="Accept" press="onUpdate" icon="sap-icon://edit"/>
        <Button text="Back"   type="Reject" press="onBack"   icon="sap-icon://nav-back"/>
      </OverflowToolbar>
    </footer>

  </Page>

</mvc:View>