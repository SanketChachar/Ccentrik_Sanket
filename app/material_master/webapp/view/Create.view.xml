<mvc:View
    controllerName="zmm_sbc_2903.controller.Create"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:form="sap.ui.layout.form">

  <Page title="Create Material" showNavButton="true" navButtonPress="onBack">

    <content>

      <form:SimpleForm
        id="crt_createForm"
        editable="true"
        layout="ResponsiveGridLayout"
        title="General Material Data"
        class="sapUiMediumMargin">

        <form:content>
          <Label text="Material Number" required="true"/>
          <Input id="crt_matnr" value="{newMaterial>/MATNR}" placeholder="e.g. MAT001"/>

          <Label text="Material Type" required="true"/>
          <Input id="crt_mtart" value="{newMaterial>/MTART}" placeholder="e.g. FERT"/>

          <Label text="Industry Sector"/>
          <Input id="crt_mbrsh" value="{newMaterial>/MBRSH}" placeholder="e.g. M"/>

          <Label text="Material Group"/>
          <Input id="crt_matkl" value="{newMaterial>/MATKL}" placeholder="e.g. 001"/>

          <Label text="Status"/>
          <Input id="crt_pstat" value="{newMaterial>/PSTAT}" placeholder="e.g. 10"/>
        </form:content>

      </form:SimpleForm>

    </content>

    <footer>
      <OverflowToolbar>
        <ToolbarSpacer/>
        <Button text="Save"  type="Accept"  press="onSave"  icon="sap-icon://save"/>
        <Button text="Clear" type="Default" press="onClear" icon="sap-icon://clear-all"/>
        <Button text="Back"  type="Reject"  press="onBack"  icon="sap-icon://nav-back"/>
      </OverflowToolbar>
    </footer>

  </Page>

</mvc:View>