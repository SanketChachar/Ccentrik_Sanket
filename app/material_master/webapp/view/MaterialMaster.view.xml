<mvc:View
 controllerName="zmm_sbc_2903.controller.MaterialMaster"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  displayBlock="true">

  <App id="app" backgroundColor="">
    <pages>
      <Page title="Material Master Functionality">
        <content>
          <VBox class="sapUiMediumMargin">
            <Title text="Select Operation" level="H2"/>
            <Button text="CREATE" press="onCreate" width="200px" class="sapUiSmallMarginBottom" type="Emphasized"/>
            <Button text="READ"   press="onRead"   width="200px" class="sapUiSmallMarginBottom"/>
            <Button text="UPDATE" press="onUpdate" width="200px" class="sapUiSmallMarginBottom"/>
            <Button text="DELETE" press="onDelete" width="200px" type="Reject"/>
          </VBox>
        </content>
      </Page>
    </pages>
  </App>

</mvc:View>